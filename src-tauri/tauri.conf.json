{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Sharelist",
  "version": "1.3.4",
  "identifier": "cn.gicp.antipro.sharelist",
  "build": {
    "beforeBuildCommand": "cd ../sharelist-client && npm run build",
    "beforeDevCommand": "cd ../sharelist-client && npm run dev",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../../sharelist-client/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sharelist",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
