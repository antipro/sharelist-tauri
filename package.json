{
  "name": "sharelist-tauri",
  "private": true,
  "version": "1.3.4",
  "scripts": {
    "dev": "cargo tauri dev",
    "build": "cargo tauri build",
    "build:mac": "cargo tauri build --target aarch64-apple-darwin",
    "build:mac-intel": "cargo tauri build --target x86_64-apple-darwin",
    "build:win": "cargo tauri build --target x86_64-pc-windows-msvc",
    "build:linux": "cargo tauri build --target x86_64-unknown-linux-gnu",
    "icons": "cargo tauri icon ../sharelist-client/static/tray.png"
  }
}
